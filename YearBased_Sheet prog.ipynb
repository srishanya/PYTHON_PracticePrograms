    "#Q1: Leap Year Check\n",
    "#leap year check\n",
    "month = int(input(\"Enter the month (1-12): \"))\n",
    "if month == 2:\n",
    "    year = int(input(\"Enter the year: \"))\n",
    "    if (year % 4 == 0 and year % 100 != 0) or (year % 400 == 0):\n",
    "        return 29\n",
    "    else:\n",
    "        return 28"
